{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=assistiq;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "AssistIQ",
    "Audience": "AssistIQ",
    "SigningKey": "dev-only-signing-key-change-before-production-32chars"
  },
  "UsageCost": {
    "DefaultInputCostPer1M": 1.25,
    "DefaultOutputCostPer1M": 10.0
  },
  "Ai": {
    "Provider": "Fake",
    "GitHubModels": {
      "Endpoint": "https://models.github.ai/inference/chat/completions",
      "Model": "openai/gpt-4.1"
    }
  },
  "ApplyMigrationsOnStartup": false,
  "SeedDemoDataOnStartup": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
